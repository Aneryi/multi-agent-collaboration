# =============================================================================
# MASE (Multi-Agent Storytelling Engine) 环境变量配置
# 复制此文件为 .env 并填入实际值
# =============================================================================

# ---- LLM 适配器 ----

# DeepSeek API 密钥（设置后自动启用 DeepSeek 适配器，无需额外配置）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek API 端点（可选，默认 https://api.deepseek.com）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名（可选，默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# LLM 适配器强制选择（可选，通常不需要设置）
# "deepseek" — 强制使用 DeepSeek
# "rule"     — 强制使用本地规则型（即使 DEEPSEEK_API_KEY 已设置）
# MASE_LLM_PROVIDER=deepseek

# ---- 数据存储 ----

# JSON 数据文件存储目录（默认 .mase_data）
# MASE_DATA_DIR=.mase_data

# ---- LangSmith 可观测性（可选） ----

# LangSmith API 密钥（设置后自动启用追踪）
# 在 https://smith.langchain.com 注册免费账号获取
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-api-key

# 启用追踪（如果设置了 API Key，默认自动设为 true）
# LANGSMITH_TRACING=true

# LangSmith 项目名（默认 mase-narrative-engine）
# LANGSMITH_PROJECT=mase-narrative-engine

# LangSmith API 端点（可选，默认 https://api.smith.langchain.com）
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
